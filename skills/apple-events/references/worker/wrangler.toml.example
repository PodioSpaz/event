name = "event-sync-api"
main = "src/index.ts"
compatibility_date = "2026-03-01"

[[d1_databases]]
binding = "DB"
database_name = "event-sync"
database_id = "REPLACE_WITH_YOUR_DATABASE_ID"
migrations_dir = "migrations"

# Daily purge of soft-deleted records older than 30 days.
[triggers]
crons = ["0 3 * * *"]
